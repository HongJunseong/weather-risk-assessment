# 로컬 파일로 override 하려면 절대 경로 입력
RISK_LATEST_PATH=

# Tableau Cloud (선택적 사용)
# DAG 하단 csv_to_hyper / publish_overwrite 주석 해제 시 필요
TABLEAU_SERVER=
TABLEAU_SITE_ID=
TABLEAU_PAT_NAME=
TABLEAU_PAT_SECRET=
TABLEAU_PROJECT_NAME=
TABLEAU_DS_NAME=
